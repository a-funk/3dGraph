{
  "name": "@a-funk/3d-graph",
  "version": "0.2.0",
  "description": "Three.js knowledge-graph exploration library with 3D layouts, flight controls, shoot-to-select interactions, and real-data examples.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/types.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-funk/3dGraph.git"
  },
  "bugs": {
    "url": "https://github.com/a-funk/3dGraph/issues"
  },
  "homepage": "https://github.com/a-funk/3dGraph#readme",
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "import": "./src/index.js"
    },
    "./graph": {
      "types": "./src/types.d.ts",
      "import": "./src/graph/index.js"
    },
    "./layouts": {
      "types": "./src/types.d.ts",
      "import": "./src/layouts/index.js"
    },
    "./controls": {
      "types": "./src/types.d.ts",
      "import": "./src/controls/index.js"
    },
    "./renderers": {
      "types": "./src/types.d.ts",
      "import": "./src/renderers/index.js"
    },
    "./generators": {
      "types": "./src/types.d.ts",
      "import": "./src/generators/index.js"
    },
    "./a11y": {
      "types": "./src/types.d.ts",
      "import": "./src/a11y/index.js"
    },
    "./styles": {
      "types": "./src/types.d.ts",
      "import": "./src/styles/index.js"
    }
  },
  "files": [
    "src/",
    "docs/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build:example": "vite build examples/vanilla --outDir ../../build/vanilla-example --emptyOutDir",
    "build:example:json": "vite build examples/json --outDir ../../build/json-example --emptyOutDir",
    "dev": "vite examples/vanilla --host 127.0.0.1",
    "dev:json": "vite examples/json --host 127.0.0.1",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "three",
    "threejs",
    "3d",
    "knowledge-graph",
    "force-directed-graph",
    "flight-controls",
    "webgl",
    "graph-visualization"
  ],
  "license": "MIT",
  "dependencies": {
    "d3-force-3d": "^3.0.6",
    "three": "^0.184.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "vite": "^7.3.3"
  }
}
